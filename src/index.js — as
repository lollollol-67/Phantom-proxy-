import { createServer } from "node:http";
import { fileURLToPath } from "url";
import { hostname } from "node:os";
import { server as wisp, logging } from "@mercuryworkshop/wisp-js/server";
import Fastify from "fastify";
import fastifyStatic from "@fastify/static";
import fastifyCookie from "@fastify/cookie";
import { libcurlPath } from "@mercuryworkshop/libcurl-transport";
import { baremuxPath } from "@mercuryworkshop/bare-mux/node";

const publicPath = fileURLToPath(new URL("../public/", import.meta.url));

// Suppress wisp noise in logs
logging.set_level(logging.NONE);

// Wisp server config
Object.assign(wisp.options, {
  allow_udp_streams: false,
  dns_servers: ["1.1.1.3", "1.0.0.3"],
});

const fastify = Fastify({
  serverFactory: (handler) => {
    return createServer()
      .on("request", (req, res) => {
        // COOP + COEP are required for SharedArrayBuffer (WebAssembly games)
        res.setHeader("Cross-Origin-Opener-Policy", "same-origin");
        res.setHeader("Cross-Origin-Embedder-Policy", "require-corp");
        handler(req, res);
      })
      .on("upgrade", (req, socket, head) => {
        if (req.url.endsWith("/wisp/")) {
          wisp.routeRequest(req, socket, head);
        } else {
          socket.end();
        }
      });
  },
});

// Cookie parsing (required for beta gate)
await fastify.register(fastifyCookie);

// ===== Private beta gate =====
const ACCESS_COOKIE = "beta_access";

// Entry point — sets session cookie and redirects to /
fastify.get("/index.html", (req, reply) => {
  reply.setCookie(ACCESS_COOKIE, "true", {
    httpOnly: true,
    sameSite: "strict",
    path: "/",
    // No maxAge = session cookie, deleted when browser closes
  });
  reply.redirect("/");
});

// Gate hook — blocks all routes unless the user has the access cookie
// or is navigating to /index.html to get it
fastify.addHook("onRequest", (req, reply, done) => {
  const hasAccess = req.cookies?.[ACCESS_COOKIE] === "true";
  const isEntry = req.url === "/index.html";

  if (hasAccess || isEntry) {
    return done();
  }

  reply.code(404).send();
});
// ===== End beta gate =====

// Serve our public files first (takes priority)
fastify.register(fastifyStatic, {
  root: publicPath,
  decorateReply: true,
});

// Serve libcurl transport (handles modern sites, TikTok, streaming)
fastify.register(fastifyStatic, {
  root: libcurlPath,
  prefix: "/libcurl/",
  decorateReply: false,
});

// Serve baremux (connection multiplexer)
fastify.register(fastifyStatic, {
  root: baremuxPath,
  prefix: "/baremux/",
  decorateReply: false,
});

// 404 fallback
fastify.setNotFoundHandler((req, reply) => {
  return reply.code(404).type("text/html").sendFile("404.html");
});

fastify.server.on("listening", () => {
  const address = fastify.server.address();
  console.log("\n👻 Phantom Proxy is running!\n");
  console.log(`   Local:   http://localhost:${address.port}`);
  console.log(`   Network: http://${hostname()}:${address.port}\n`);
});

process.on("SIGINT", shutdown);
process.on("SIGTERM", shutdown);

function shutdown() {
  console.log("\nShutting down Phantom...");
  fastify.close();
  process.exit(0);
}

let port = parseInt(process.env.PORT || "");
if (isNaN(port)) port = 8080;

fastify.listen({ port, host: "0.0.0.0" });
